FROM node:20-alpine

WORKDIR /app

# Copy backend package files specifically
COPY backend/package*.json ./backend/

# Install backend dependencies
WORKDIR /app/backend
RUN npm install

# Return to root app directory and copy all files
WORKDIR /app
COPY . .

# Install root dependencies (which contains shared libraries like supabase)
RUN npm install --omit=dev

# Expose Gateway Port
EXPOSE 3000

# Start Express Server from within the backend directory so relative paths work
WORKDIR /app/backend
CMD ["node", "index.js"]
